# Find And Study Academy - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================
# PostgreSQL connection string
# For local development: postgresql://username:password@localhost:5432/findandstudy
# For Hostinger VPS: postgresql://username:password@localhost:5432/findandstudy
DATABASE_URL=postgresql://username:password@localhost:5432/findandstudy

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Port to run the server on (default: 5000)
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# Application URL (used in emails)
APP_URL=http://localhost:5000

# ===========================================
# EMAIL CONFIGURATION (SMTP)
# ===========================================
# SMTP server settings for sending emails
# Works with Gmail SMTP, Yandex, or any SMTP provider

# SMTP Host (e.g., smtp.gmail.com, smtp.yandex.com)
SMTP_HOST=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Authentication
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Use secure connection (true for port 465, false for 587)
SMTP_SECURE=false

# From email address
SMTP_FROM=noreply@findandstudy.com

# From name displayed in emails
SMTP_FROM_NAME=Find & Study Academy

# ===========================================
# N8N CHATBOT INTEGRATION (Optional)
# ===========================================
# Webhook URL for N8N chatbot integration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chatbot

# ===========================================
# GMAIL SMTP SETUP GUIDE (for Gmail users)
# ===========================================
# 1. Go to Google Account > Security
# 2. Enable 2-Step Verification
# 3. Go to App passwords
# 4. Create a new app password for "Mail"
# 5. Use that password as SMTP_PASS
#
# Example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx (app password)
# SMTP_SECURE=false

# ===========================================
# YANDEX SMTP SETUP GUIDE (for Yandex users)
# ===========================================
# SMTP_HOST=smtp.yandex.com
# SMTP_PORT=587
# SMTP_USER=your-email@yandex.com
# SMTP_PASS=your-password
# SMTP_SECURE=false
