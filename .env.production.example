# =============================================================================
# Find And Study — Production Environment Variables
# =============================================================================
# Bu dosyayı .env.production olarak kopyalayın ve gerçek değerleri girin.
# .env.production ASLA git'e commit edilmemelidir (.gitignore içinde dışlanmıştır).
# =============================================================================

NODE_ENV=production
PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# Veritabanı (Hostinger VPS üzerinde yerel PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://findandstudy_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/findandstudy

# ─────────────────────────────────────────────────────────────────────────────
# Oturum / Güvenlik (DEPLOY ÖNCESİ DOLDURUN)
# ─────────────────────────────────────────────────────────────────────────────
# Üret: openssl rand -hex 64
SESSION_SECRET=GENERATE_WITH_openssl_rand_hex_64

# CORS izinli domain
ALLOWED_ORIGIN=https://academy.findandstudy.com

# ─────────────────────────────────────────────────────────────────────────────
# İlk Admin Parolası (sadece veritabanında admin yoksa kullanılır)
# ─────────────────────────────────────────────────────────────────────────────
# Boş bırakılırsa seed atlanır — yeni kuruluşta admin yaratılmaz.
# İlk kez doldurun, admin oluşunca dosyadan silebilirsiniz.
ADMIN_INITIAL_EMAIL=en@findandstudy.com
ADMIN_INITIAL_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# SMTP (e-posta bildirimleri için)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yandex.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@findandstudy.com
SMTP_PASS=CHANGE_ME
SMTP_FROM_NAME=Find & Study Academy

# ─────────────────────────────────────────────────────────────────────────────
# n8n Chatbot (opsiyonel, eski geri-dönüş yolu)
# ─────────────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Object Storage (opsiyonel — yerel /uploads kullanılıyorsa boş bırakın)
# ─────────────────────────────────────────────────────────────────────────────
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
